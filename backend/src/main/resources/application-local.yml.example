# This file is optional.
# Spring Boot already reads ../.env by default when you run the backend from the backend directory.
# Copy this file to application-local.yml only when you need backend-only overrides.

server:
  # Override the backend port if 8080 is already occupied.
  port: ${SERVER_PORT:8080}

spring:
  datasource:
    # Change DB_HOST if your database is not on the same machine.
    # If your local Docker MySQL port conflicts, first update MYSQL_PORT in the root .env file.
    url: jdbc:mysql://${DB_HOST:127.0.0.1}:${DB_PORT:${MYSQL_PORT:3306}}/${DB_NAME:${MYSQL_DATABASE:ai_health}}?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
    # If you prefer separate backend credentials, override them here.
    username: ${DB_USER:${MYSQL_USER:health_app}}
    password: ${DB_PASSWORD:${MYSQL_PASSWORD:health_app_123}}
    # Keep the app startable even when the database container is temporarily unavailable.
    hikari:
      initialization-fail-timeout: 0
  jpa:
    database-platform: org.hibernate.dialect.MySQLDialect
    # Keep none for scaffold stage. Change this later when entities and migrations are in place.
    hibernate:
      ddl-auto: none
    properties:
      hibernate:
        boot:
          allow_jdbc_metadata_access: false

logging:
  level:
    root: info
    com.health.backend: info

app:
  cors:
    # Add extra origins if someone runs the frontend on another port.
    allowed-origins: ${CORS_ALLOWED_ORIGINS:http://127.0.0.1:5173,http://localhost:5173}
