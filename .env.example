# Copy this file to .env before you start the project.
# Mac/Linux: cp .env.example .env
# Windows PowerShell: Copy-Item .env.example .env

# Mock 开关 —— 后端 auth 接口未就绪时设为 true
# VITE_MOCK_AUTH=true

# Frontend development server
VITE_HOST=127.0.0.1
VITE_PORT=5173
# Use /api in local development so Vite can proxy requests to Spring Boot.
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:8080

# Backend runtime
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
# Backend reads these values directly from .env through Spring config import.
DB_HOST=127.0.0.1
# Optional backend overrides.
# Keep these commented out in normal local development so the backend follows MYSQL_* below.
# Uncomment them only when the backend should connect to a different database target.
# DB_PORT=3306
# DB_NAME=ai_health
# DB_USER=health_app
# DB_PASSWORD=health_app_123
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# AI Service (FastAPI / Python)
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=8000

# AI API (OpenAI-compatible, used by Microsoft Agent Framework)
# Fill in your own key to enable real AI analysis; leave empty for mock mode.
AI_API_KEY=
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# JWT settings for backend authentication.
# Change JWT_SECRET in real shared/demo environments. Keep it at least 32 characters.
JWT_SECRET=dev-only-change-this-secret-key-for-ai-health-management-system
JWT_EXPIRE_MINUTES=120

# Docker MySQL
# If 3306 is already occupied on your machine, change MYSQL_PORT here first.
MYSQL_PORT=3306
MYSQL_DATABASE=ai_health
MYSQL_USER=health_app
MYSQL_PASSWORD=health_app_123
# Change this on every machine before sharing screenshots or demos.
MYSQL_ROOT_PASSWORD=change_this_root_password
TZ=Asia/Shanghai
